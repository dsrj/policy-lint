{
  "ip_groups": {
    "prod": ["10.0.0.0/16"],
    "db": ["10.0.5.5/32"],
    "internet": ["0.0.0.0/0"]
  },

  "rule_collection_groups": [

    {
      "name": "rcg-deny",
      "priority": 100,

      "network_rule_collections": [
        {
          "name": "deny-all",
          "priority": 100,
          "action": "deny",
          "rules": [
            {
              "name": "deny_prod",
              "priority": 100,
              "source": ["prod"],
              "destination": ["internet"],
              "ports": ["*"],
              "protocol": "Any"
            }
          ]
        }
      ],

      "app_rule_collections": []
    },

    {
      "name": "rcg-allow",
      "priority": 200,

      "network_rule_collections": [
        {
          "name": "allow-db",
          "priority": 100,
          "action": "allow",
          "rules": [
            {
              "name": "allow_db",
              "priority": 100,
              "source": ["db"],
              "destination": ["internet"],
              "ports": ["443"],
              "protocol": "TCP"
            }
          ]
        }
      ],

      "app_rule_collections": [
        {
          "name": "app-allow",
          "priority": 100,
          "action": "allow",
          "rules": [
            {
              "name": "allow_google",
              "priority": 100,
              "source": ["prod"],
              "fqdns": ["google.com"]
            }
          ]
        }
      ]
    }
  ]
}