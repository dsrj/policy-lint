{
  "ip_groups": {
    "prod_networks": ["10.0.0.0/16", "10.1.0.0/16"],
    "dev_networks": ["10.2.0.0/16"],
    "critical_db": ["10.0.5.5/32"],
    "bad_group": ["invalid-ip"]
  },

  "network_rules": [

    {
      "name": "deny_all_prod",
      "priority": 100,
      "action": "deny",
      "source": ["prod_networks"],
      "destination": ["0.0.0.0/0"],
      "ports": ["*"],
      "protocol": "Any"
    },

    {
      "name": "shadowed_allow_db",
      "priority": 200,
      "action": "allow",
      "source": ["critical_db"],
      "destination": ["0.0.0.0/0"],
      "ports": ["443"],
      "protocol": "TCP",
      "justification": "This rule is shadowed intentionally"
    },

    {
      "name": "duplicate_rule_1",
      "priority": 300,
      "action": "allow",
      "source": ["10.0.0.0/16"],
      "destination": ["8.8.8.8/32"],
      "ports": ["53"],
      "protocol": "UDP"
    },

    {
      "name": "duplicate_rule_2",
      "priority": 301,
      "action": "allow",
      "source": ["10.0.0.0/16"],
      "destination": ["8.8.8.8/32"],
      "ports": ["53"],
      "protocol": "UDP"
    },

    {
      "name": "protocol_mismatch_rule_1",
      "priority": 400,
      "action": "allow",
      "source": ["10.0.0.0/16"],
      "destination": ["8.8.4.4/32"],
      "ports": ["53"],
      "protocol": "TCP"
    },

    {
      "name": "protocol_mismatch_rule_2",
      "priority": 401,
      "action": "allow",
      "source": ["10.0.0.0/16"],
      "destination": ["8.8.4.4/32"],
      "ports": ["53"],
      "protocol": "UDP"
    },

    {
      "name": "invalid_cidr_rule",
      "priority": 500,
      "action": "allow",
      "source": ["bad_group"],
      "destination": ["not-a-cidr"],
      "ports": ["80"],
      "protocol": "TCP"
    },

    {
      "name": "empty_ports_rule",
      "priority": 600,
      "action": "allow",
      "source": ["dev_networks"],
      "destination": ["1.1.1.1/32"],
      "ports": [],
      "protocol": "TCP"
    },

    {
      "name": "overly_permissive_ports",
      "priority": 700,
      "action": "allow",
      "source": ["dev_networks"],
      "destination": ["1.1.1.1/32"],
      "ports": ["*"],
      "protocol": "TCP"
    }

  ],

  "app_rules": [

    {
      "name": "wildcard_rule",
      "priority": 1000,
      "action": "allow",
      "source": ["10.0.0.0/24"],
      "fqdns": ["*"]
    },

    {
      "name": "invalid_fqdn_rule",
      "priority": 1100,
      "action": "allow",
      "source": ["10.0.0.0/24"],
      "fqdns": ["://bad-domain"]
    },

    {
      "name": "valid_rule",
      "priority": 1200,
      "action": "allow",
      "source": ["10.0.0.0/24"],
      "fqdns": ["example.com", "api.example.com"]
    }

  ]
}